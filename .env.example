RUNOOB_ROOT_URL=https://www.runoob.com/python3/python3-tutorial.html
RUNOOB_TOPIC_HINT=python
RUNOOB_MAX_BLOCKS=4
RUNOOB_TIMEOUT=20

# 仅需配置一种推送方式
PUSH_PROVIDER=serverchan

# Server酱
SERVERCHAN_SENDKEY=

# Bark
BARK_DEVICE_KEY=
BARK_PUSH_URL=
BARK_GROUP=runoob-daily

# PushPlus
PUSHPLUS_TOKEN=

# 微信公众号图文
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_THUMB_MEDIA_ID=
WECHAT_AUTHOR=
WECHAT_MP_MODE=draft
WECHAT_TITLE_PREFIX=晨读｜
WECHAT_NEED_OPEN_COMMENT=0
WECHAT_ONLY_FANS_CAN_COMMENT=0

# 可选：AI 晨读卡片（兼容 OpenAI Chat Completions 接口）
LLM_SUMMARY_ENABLED=0
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=40
LLM_SUMMARY_MAX_INPUT_CHARS=2800
